# Copie este arquivo para .env e preencha os valores

# URL ENCRIPTADA do Duttyfy (Painel → Integrações e Chaves → Chaves API → Gerar URL encriptada)
DUTTYFY_URL=https://...sua-url-encriptada...

# Token da API da Utmify (Painel Utmify → Integrações → API de Credenciais)
UTMIFY_API_TOKEN=...seu-token-utmify...

# Facebook Conversions API (server-side). O TOKEN é secreto — nunca vai pro front.
FB_PIXEL_ID=...seu-pixel-id...
FB_CAPI_TOKEN=...seu-token-capi...

# Supabase — store persistente do contexto do pedido (necessário em serverless)
SUPABASE_URL=https://...seu-projeto....supabase.co
SUPABASE_SERVICE_ROLE_KEY=...service-role-key-secreta...

# Porta do servidor (separada do servidor estático do funil)
PORT=3002
